    receiverNumber: "",
    zone: "",
    productName: "", // Added
    model: "",
    quantity: 0,
  });
  useEffect(() => {
    if (open && challan && product) {
      setFormData({
        customerName: challan.customerName || "",
        address: challan.address || "",
        thana: challan.thana || "",
        district: challan.district || "",
        receiverNumber: challan.receiverNumber || "",
        zone: challan.zone || "",
